# Anything that doesn't need to ship inside the Fly image.
# Mirrors .gitignore for the dev-local stuff, plus excludes things that
# are checked in but only useful at build/test/dev time.

# Python
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
htmlcov/
*.egg-info/
dist/
build/

# Environments
.env
.env.local
.env.*.local
!.env.example

# Editors / OS
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Git / CI / Claude
.git/
.gitignore
.gitattributes
.github/
.claude/

# Tests, docs, and project-management files don't run in production.
tests/
docs/
tasks/
README.md
CLAUDE.md
*.md

# Fly metadata — flyctl injects what it needs at build time.
fly.toml
.fly/
.dockerignore

# Logs and temp
*.log
logs/
*.tmp
.cache/
