APP_ENV=dev
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/marketdb
TZ=America/New_York

# Anthropic API key for the LLM client (Phase 2). Required for /v1/research/*
# endpoints and the eval harness. Get one at https://console.anthropic.com.
# In production, set via `fly secrets set ANTHROPIC_API_KEY=...` — never commit.
ANTHROPIC_API_KEY=

# NewsAPI dev tier key (https://newsapi.org). Free tier is 100 requests/day,
# fine for on-demand research. Optional — when missing, the news-ingestion
# service silently skips the NewsAPI provider and only uses RSS feeds.
NEWSAPI_KEY=

# SEC EDGAR fair-access compliance. SEC requires a User-Agent identifying
# the client (https://www.sec.gov/os/accessing-edgar-data). Defaults to the
# public repo URL; override locally if you fork.
EDGAR_USER_AGENT=

# On-disk cache directory for fetched SEC filings. Filings are immutable
# (amendments get new accession numbers) so the cache never invalidates.
# Default: .edgar_cache (gitignored).
EDGAR_CACHE_DIR=

# FRED API key (https://fred.stlouisfed.org/docs/api/api_key.html). Free
# tier is 120 req/min. Optional — when missing, fetch_macro silently
# returns metadata claims with None-valued data claims rather than 500ing.
FRED_API_KEY=

# Shared-password gate for /v1/research/* (Phase 3.0). Empty = auth OFF
# (fine for local dev). When set, every request must carry
# `Authorization: Bearer <BACKEND_SHARED_SECRET>`. Generate a random
# value e.g. `python -c "import secrets; print(secrets.token_urlsafe(32))"`
# and put the same value in the frontend's VITE_SHARED_SECRET. In prod:
# `fly secrets set BACKEND_SHARED_SECRET=...`.
BACKEND_SHARED_SECRET=

# CORS allowlist origin for the frontend (Phase 3.0). Empty = no CORS
# middleware (same-origin only). When set, exactly one origin is
# allowlisted, e.g. `https://market-agent.vercel.app`. Never `*` — we
# ship an Authorization header which CORS treats as credential-adjacent.
FRONTEND_ORIGIN=
