APP_ENV=dev
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/marketdb
TZ=America/New_York

# Anthropic API key for the LLM client (Phase 2). Required for /v1/research/*
# endpoints and the eval harness. Get one at https://console.anthropic.com.
# In production, set via `fly secrets set ANTHROPIC_API_KEY=...` — never commit.
ANTHROPIC_API_KEY=

# NewsAPI dev tier key (https://newsapi.org). Free tier is 100 requests/day,
# fine for on-demand research. Optional — when missing, the news-ingestion
# service silently skips the NewsAPI provider and only uses RSS feeds.
NEWSAPI_KEY=
